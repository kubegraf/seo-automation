# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub settings (for publishing articles via GitHub API)
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=kubegraf/seo-automation
GITHUB_BRANCH=main

# Optional: Google Search Console API
GOOGLE_SEARCH_CONSOLE_KEY=optional

# Pipeline settings
ARTICLES_PER_RUN=3
KEYWORDS_PER_RUN=20
