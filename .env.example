# =============================================================================
# SEO Automation Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql+asyncpg://seo_user:seo_password@postgres:5432/seo_automation
POSTGRES_USER=seo_user
POSTGRES_PASSWORD=seo_password
POSTGRES_DB=seo_automation
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# =============================================================================
# AI / LLM APIs
# =============================================================================
# Anthropic Claude API key (primary LLM)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API key (fallback LLM)
OPENAI_API_KEY=sk-your-openai-key-here

# =============================================================================
# SEO APIs
# =============================================================================
# SerpAPI for keyword research and SERP analysis
SERPAPI_KEY=your-serpapi-key-here

# DataForSEO API credentials
DATAFORSEO_LOGIN=your-dataforseo-login
DATAFORSEO_PASSWORD=your-dataforseo-password

# Google Search Console API
GOOGLE_SEARCH_CONSOLE_CREDENTIALS_PATH=/app/credentials/gsc_credentials.json
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://kubegraf.com

# =============================================================================
# GitHub (for publishing)
# =============================================================================
GITHUB_TOKEN=ghp_your-github-token-here
GITHUB_REPO_OWNER=kubegraf
GITHUB_REPO_NAME=kubegraf.com
GITHUB_BRANCH=main
GITHUB_CONTENT_PATH=content/blog

# =============================================================================
# Application Settings
# =============================================================================
# Environment: development, staging, production
ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Service ports (internal)
SCHEDULER_PORT=8000
KEYWORD_DISCOVERY_PORT=8001
COMPETITOR_ANALYSIS_PORT=8002
CONTENT_GENERATION_PORT=8003
SEO_OPTIMIZATION_PORT=8004
PUBLISHING_PORT=8005
BACKLINK_AUTOMATION_PORT=8006
SEO_ANALYTICS_PORT=8007
DASHBOARD_PORT=8501

# =============================================================================
# Content Settings
# =============================================================================
# Target website info
SITE_NAME=Kubegraf
SITE_URL=https://kubegraf.com
SITE_DESCRIPTION=AI-powered Kubernetes monitoring and incident management platform

# Content generation settings
DEFAULT_ARTICLE_WORD_COUNT=2000
MIN_ARTICLE_WORD_COUNT=1500
MAX_ARTICLE_WORD_COUNT=4000
ARTICLES_PER_WEEK=5

# =============================================================================
# Celery
# =============================================================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# =============================================================================
# Monitoring
# =============================================================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# =============================================================================
# Security
# =============================================================================
SECRET_KEY=your-super-secret-key-change-in-production
API_KEY=your-internal-api-key-for-service-auth

# =============================================================================
# Scheduler
# =============================================================================
# Cron schedule for full pipeline (default: every Monday at 2 AM)
PIPELINE_CRON_SCHEDULE=0 2 * * 1
# Cron schedule for daily rankings check (default: 6 AM daily)
RANKINGS_CRON_SCHEDULE=0 6 * * *
